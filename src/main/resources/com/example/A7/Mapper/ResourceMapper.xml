<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.A7.Mapper.ResourceMapper">

    <resultMap id="BaseResultMap" type="com.example.A7.DO.ResourceDO">
        <id property="id" column="id" />
        <result property="title" column="title" />
        <result property="type" column="type" />
        <result property="url" column="url" />
        <result property="chapterId" column="chapter_id" />
        <result property="createTime" column="create_time" />
        <result property="size" column="size" />
        <result property="duration" column="duration" />
    </resultMap>
    
    <sql id="Base_Column_List">
        id, title, type, url, chapter_id, create_time, size, duration
    </sql>

    <insert id="add" parameterType="com.example.A7.DO.ResourceDO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO resource (
            title, type, url, chapter_id, create_time, size, duration
        ) VALUES (
            #{title}, #{type}, #{url}, #{chapterId}, now(), #{size}, #{duration}
        )
    </insert>
    
    <insert id="batchAdd" parameterType="java.util.List">
        INSERT INTO resource (
            title, type, url, chapter_id, create_time, size, duration
        ) VALUES 
        <foreach collection="list" item="item" separator=",">
            (
                #{item.title}, #{item.type}, #{item.url}, #{item.chapterId},
                now(), #{item.size}, #{item.duration}
            )
        </foreach>
    </insert>

    <update id="update" parameterType="com.example.A7.DO.ResourceDO">
        UPDATE resource
        <set>
            <if test="title != null">title = #{title},</if>
            <if test="type != null">type = #{type},</if>
            <if test="url != null">url = #{url},</if>
            <if test="chapterId != null">chapter_id = #{chapterId},</if>
            <if test="size != null">size = #{size},</if>
            <if test="duration != null">duration = #{duration},</if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 根据ID查询 -->
    <select id="findById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM resource
        WHERE id = #{id}
    </select>
    <select id="findByChapterIds" resultType="com.example.A7.DO.ResourceDO">
    SELECT * FROM resource
    WHERE chapter_id IN
    <foreach collection="chapterIds" item="id" open="(" separator="," close=")">
        #{id}
    </foreach>
</select>
    <!-- 根据章节ID查询 -->
    <select id="findByChapterId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM resource
        WHERE chapter_id = #{chapterId}
    </select>
    <!-- 统计课程资源数 -->
<select id="countByCourseId" resultType="int">
    SELECT COUNT(*) FROM resource WHERE course_id = #{courseId}
</select>
    <!-- 根据标题查询 -->
    <select id="findByTitle" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM resource
        WHERE title LIKE CONCAT('%', #{title}, '%')
    </select>
    
    <!-- 根据类型查询 -->
    <select id="findByType" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM resource
        WHERE type = #{type}
    </select>

    <!-- 查询所有资源 -->
    <select id="findAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM resource
    </select>
    
    <!-- 分页查询资源 -->
    <select id="findByPage" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM resource
        LIMIT #{offset}, #{limit}
    </select>

    <!-- 删除资源 -->
    <delete id="delete">
        DELETE FROM resource WHERE id = #{id}
    </delete>
    <delete id="deleteByChapterId">
        DELETE FROM resource WHERE chapter_id = #{chapterId}
    </delete>
</mapper> 