<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.A7.Mapper.ChapterMapper">

    <resultMap id="BaseResultMap" type="com.example.A7.DO.ChapterDO">
        <id property="id" column="id" />
        <result property="courseId" column="course_id" />
        <result property="title" column="title" />
        <result property="orderNum" column="order_num" />
        <result property="description" column="description" />
    </resultMap>
    
    <sql id="Base_Column_List">
        id, course_id, title, order_num, description
    </sql>

    <insert id="add" parameterType="com.example.A7.DO.ChapterDO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO chapter (
            course_id, title, order_num, description
        ) VALUES (
            #{courseId}, #{title}, #{orderNum}, #{description}
        )
    </insert>
    <!-- 统计课程章节数 -->
<select id="countByCourseId" resultType="int">
    SELECT COUNT(*) FROM chapter WHERE course_id = #{courseId}
</select>
    <insert id="batchAdd" parameterType="java.util.List">
        INSERT INTO chapter (
            course_id, title, order_num, description
        ) VALUES 
        <foreach collection="list" item="item" separator=",">
            (
                #{item.courseId}, #{item.title}, #{item.orderNum}, #{item.description}
            )
        </foreach>
    </insert>

    <update id="update" parameterType="com.example.A7.DO.ChapterDO">
        UPDATE chapter
        <set>
            <if test="courseId != null">course_id = #{courseId},</if>
            <if test="title != null">title = #{title},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="description != null">description = #{description},</if>
        </set>
        WHERE id = #{id}
    </update>
    
    <update id="updateOrderNum">
        UPDATE chapter SET order_num = #{orderNum} WHERE id = #{id}
    </update>

    <!-- 根据ID查询 -->
    <select id="findById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM chapter
        WHERE id = #{id}
    </select>
    
    <!-- 根据课程ID查询 -->
    <select id="findByCourseId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM chapter
        WHERE course_id = #{courseId}
    </select>
    
    <!-- 根据课程ID查询，按排序号排序 -->
    <select id="findByCourseIdOrdered" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM chapter
        WHERE course_id = #{courseId}
        ORDER BY order_num ASC
    </select>
    
    <!-- 根据标题查询 -->
    <select id="findByTitle" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM chapter
        WHERE title LIKE CONCAT('%', #{title}, '%')
    </select>

    <!-- 查询所有章节 -->
    <select id="findAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM chapter
    </select>

    <!-- 删除章节 -->
    <delete id="delete">
        DELETE FROM chapter WHERE id = #{id}
    </delete>
    <delete id="deleteByCourseId">
        DELETE FROM chapter WHERE course_id = #{courseId}
    </delete>
</mapper> 