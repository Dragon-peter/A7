<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.A7.Mapper.TeacherMapper">

    <resultMap id="BaseResultMap" type="com.example.A7.DO.TeacherDO">
        <id property="id" column="id" />
        <result property="userId" column="user_id" />
        <result property="department" column="department" />
        <result property="title" column="title" />
        <result property="researchArea" column="research_area" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>
    
    <sql id="Base_Column_List">
        id, user_id, department, title, research_area, create_time, update_time
    </sql>

    <insert id="add" parameterType="com.example.A7.DO.TeacherDO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO teacher (
            user_id, department, title, research_area, create_time, update_time
        ) VALUES (
            #{userId}, #{department}, #{title}, #{researchArea}, now(), now()
        )
    </insert>
    
    <insert id="batchAdd" parameterType="java.util.List">
        INSERT INTO teacher (
            user_id, department, title, research_area, create_time, update_time
        ) VALUES 
        <foreach collection="list" item="item" separator=",">
            (
                #{item.userId}, #{item.department},
                #{item.title}, #{item.researchArea}, now(), now()
            )
        </foreach>
    </insert>

    <update id="update" parameterType="com.example.A7.DO.TeacherDO">
        UPDATE teacher
        <set>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="department != null">department = #{department},</if>
            <if test="title != null">title = #{title},</if>
            <if test="researchArea != null">research_area = #{researchArea},</if>
            update_time = now()
        </set>
        WHERE id = #{id}
    </update>

    <!-- 根据ID查询 -->
    <select id="findById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM teacher
        WHERE id = #{id}
    </select>

    <!-- 根据用户ID查询 -->
    <select id="findByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM teacher
        WHERE user_id = #{userId}
    </select>

    <!-- 根据部门查询 -->
    <select id="findByDepartment" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM teacher
        WHERE department = #{department}
    </select>

    <!-- 根据职称查询 -->
    <select id="findByTitle" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM teacher
        WHERE title = #{title}
    </select>

    <!-- 根据研究领域查询 -->
    <select id="findByResearchArea" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM teacher
        WHERE research_area LIKE CONCAT('%', #{researchArea}, '%')
    </select>

    <!-- 查询所有教师 -->
    <select id="findAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM teacher
    </select>
    
    <!-- 分页查询教师 -->
    <select id="findByPage" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM teacher
        LIMIT #{offset}, #{limit}
    </select>
    
    <!-- 统计教师总数 -->
    <select id="countTotal" resultType="int">
        SELECT COUNT(1) FROM teacher
    </select>

    <!-- 删除教师 -->
    <delete id="delete">
        DELETE FROM teacher WHERE id = #{id}
    </delete>

    <!-- 根据姓名查询，需要关联用户表 -->
    <select id="findByRealName" resultMap="BaseResultMap">
        SELECT t.* FROM teacher t
        JOIN user u ON t.user_id = u.id
        WHERE u.real_name = #{realName}
    </select>
</mapper>
