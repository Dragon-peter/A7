<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.A7.Mapper.CourseMapper">

    <resultMap id="BaseResultMap" type="com.example.A7.DO.CourseDO">
        <id property="id" column="id" />
        <result property="name" column="name" />
        <result property="code" column="code" />
        <result property="description" column="description" />
        <result property="credit" column="credit" />
        <result property="teacherId" column="teacher_id" />
        <result property="status" column="status" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>
    
    <sql id="Base_Column_List">
        id, name, code, description, credit, teacher_id, status, create_time, update_time
    </sql>

    <insert id="add" parameterType="com.example.A7.DO.CourseDO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO course (
            name, code, description, credit, teacher_id, status, create_time, update_time
        ) VALUES (
            #{name}, #{code}, #{description}, #{credit}, #{teacherId}, #{status}, now(), now()
        )
    </insert>
    
    <insert id="batchAdd" parameterType="java.util.List">
        INSERT INTO course (
            name, code, description, credit, teacher_id, status, create_time, update_time
        ) VALUES 
        <foreach collection="list" item="item" separator=",">
            (
                #{item.name}, #{item.code}, #{item.description}, #{item.credit},
                #{item.teacherId}, #{item.status}, now(), now()
            )
        </foreach>
    </insert>

    <update id="update" parameterType="com.example.A7.DO.CourseDO">
        UPDATE course
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="code != null">code = #{code},</if>
            <if test="description != null">description = #{description},</if>
            <if test="credit != null">credit = #{credit},</if>
            <if test="teacherId != null">teacher_id = #{teacherId},</if>
            <if test="status != null">status = #{status},</if>
            update_time = now()
        </set>
        WHERE id = #{id}
    </update>
    
    <update id="updateStatus">
        UPDATE course SET status = #{status}, update_time = now() WHERE id = #{id}
    </update>

    <!-- 根据名称查询 -->
    <select id="findByName" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM course
        WHERE name LIKE CONCAT('%', #{name}, '%')
    </select>
    
    <!-- 根据ID查询 -->
    <select id="findById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM course
        WHERE id = #{id}
    </select>
    
    <!-- 根据课程代码查询 -->
    <select id="findByCode" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM course
        WHERE code = #{code}
    </select>
    
    <!-- 根据教师ID查询 -->
    <select id="findByTeacherId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM course
        WHERE teacher_id = #{teacherId}
    </select>


    <!-- 根据状态查询 -->
    <select id="findByStatus" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM course
        WHERE status = #{status}
    </select>

    <!-- 查询所有课程 -->
    <select id="findAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM course
    </select>
    
    <!-- 分页查询课程 -->
    <select id="findByPage" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM course
        LIMIT #{offset}, #{limit}
    </select>
    
    <!-- 统计课程总数 -->
    <select id="countTotal" resultType="int">
        SELECT COUNT(1) FROM course
    </select>

    <!-- 删除课程 -->
    <delete id="delete">
        DELETE FROM course WHERE id = #{id}
    </delete>
</mapper> 